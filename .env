# Machrou3i Backend Configuration
# Copy this to .env and fill in your keys

# MongoDB
MONGO_URI=mongodb://localhost:27017/machrou3i

# Server
PORT=5000

# AI API Keys (NEVER commit real keys to version control)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# JWT
JWT_SECRET=machrou3i_jwt_secret_change_in_production
JWT_REFRESH_SECRET=machrou3i_refresh_secret_change_in_production
